# Production Environment Variables for Hostinger Deployment

# API Configuration - Using same backend as mobile app
NEXT_PUBLIC_API_URL=https://food.amritkan.com/api

# Razorpay Configuration - Use LIVE keys for production
# Get your live keys from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

# Node Environment
NODE_ENV=production

# Port (Hostinger will assign this automatically)
PORT=3000
